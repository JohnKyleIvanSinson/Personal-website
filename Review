<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Review</title>
    <style>
        body {
            margin: 0;
            background: url(Images/BACKGROUND.png) no-repeat center fixed;
            background-size: cover;
            font-family: Arial, sans-serif;
            color: white;
            text-align: center; /* Center text for simplicity */
        }
        /* Go Back Button Styles */
        .back {
            position: absolute; /* Positioning it at the top left */
            top: 20px;
            left: 20px;
            width: 160px;
            height: auto;
        }
        /* Centering the Ani-Score */
        .Ani-Score {
            width: 200px;
            margin-top: 50px; /* Space from the top */
        }
        .review-container {
            display: flex;
            flex-wrap: wrap; /* Wrap cards on smaller screens */
            justify-content: center; /* Center cards */
            margin-top: 20px;
        }
        .review-card {
            background: black; /* Pure black background */
            padding: 15px;
            margin: 10px;
            width: 200px; /* Fixed width for uniformity */
            /* Removed border-radius for sharp edges */
        }
        h3 {
            margin: 0;
        }
    </style>
</head>
<body>

    <a href="index.html">
        <img src="Images/Goback.png" alt="Go Back" class="back">
    </a>

    <img src="Images/Ani-Scope.png" alt="Ani-Score" class="Ani-Score">

    <!-- Review Cards -->
    <div class="review-container">
        <div class="review-card">
            <h3>Website Features</h3>
            <p>Easy navigation.</p>
        </div>
        <div class="review-card">
            <h3>Design Quality</h3>
            <p>Modern and attractive.</p>
        </div>
        <div class="review-card">
            <h3>Loading Speed</h3>
            <p>Fast loading times.</p>
        </div>
        <div class="review-card">
            <h3>Mobile Friendly</h3>
            <p>Works well on mobile devices.</p>
        </div>
        <div class="review-card">
            <h3>Content Variety</h3>
            <p>Wide range of topics.</p>
        </div>
        <div class="review-card">
            <h3>User Engagement</h3>
            <p>Interactive elements.</p>
        </div>
        <div class="review-card">
            <h3>Feedback</h3>
            <p>Updates based on feedback.</p>
        </div>
        <div class="review-card">
            <h3>Support Access</h3>
            <p>Easy support access.</p>
        </div>
    </div>

</body>
</html>

